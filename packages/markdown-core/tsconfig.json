{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "types": ["node"],
    "skipLibCheck": true,
    "outDir": "dist",
    "strictNullChecks": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src", "./dev.ts"],
  "exclude": ["node_modules", "dist"]
}
